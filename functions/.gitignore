# Compiled output (TypeScript -> lib/), regenerated by `npm run build`.
# Ignore the whole dir so stray build artifacts (.d.ts, .tsbuildinfo, *.bak-*)
# can't be committed by accident. Anchored with a leading slash so it only
# matches the top-level build output — an unanchored `lib/` also matches the
# `src/lib/` source dir, which silently dropped new source files from commits.
/lib/

# TypeScript v1 declaration files
typings/

# Node.js dependency directory
node_modules/
*.local
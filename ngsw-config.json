{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "appData": {
    "version": "1.0.0",
    "releases": [
      {
        "version": "1.0.0",
        "changes": [
          "Added a \"What's new\" change log to the update prompt"
        ]
      }
    ]
  },
  "navigationUrls": [
    "/**",
    "!/**/*.*",
    "!/firestore/**",
    "!/identitytoolkit/**"
  ],
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "team-crests",
      "urls": [
        "https://crests.football-data.org/**"
      ],
      "cacheConfig": {
        "maxSize": 200,
        "maxAge": "30d",
        "strategy": "performance"
      }
    }
  ]
}

rules_version = '2';

// Goalden Firestore security rules.
//
// Philosophy:
//   1. Reads — open to any authenticated user where the data is intended for
//      cross-user features (leaderboards, league discovery via invite code).
//      Owner-only otherwise.
//   2. Writes — clients write ONLY their own predictions / podium picks /
//      user profile, with strict field whitelists and validation. Everything
//      else (fixtures, totals, leagues, league members, leagues_public) is
//      server-only via Cloud Functions / Admin SDK.
//   3. Lock-time enforcement — predictions writeable only while the relevant
//      fixture is still TIMED and its kickoff is in the future. Podium picks
//      writeable only until the tournament opening date.
//
// Anything not explicitly allowed below is denied by the catch-all at the
// bottom of the file.

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- helpers ---------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isLeagueMember(leagueId) {
      return exists(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid));
    }

    /**
     * Reads the caller's user doc and checks whether their `roles` array
     * includes 'admin'. Admins can create/manage global leagues via Cloud
     * Functions; this helper is also a defence-in-depth check in case
     * client-side admin gating is bypassed.
     *
     * `roles` is set via the Firestore console initially. Once an admin
     * exists, they grant other admins via the planned admin UI (which
     * calls a Cloud Function that bypasses these rules using Admin SDK).
     */
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && 'admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('roles', []);
    }

    function fixture(matchId) {
      return get(/databases/$(database)/documents/fixtures/$(matchId)).data;
    }

    function validDisplayName(name) {
      return name is string && name.size() >= 2 && name.size() <= 30;
    }

    function isUnscoredPrediction() {
      return request.resource.data.points == null
        && request.resource.data.submittedAt is timestamp;
    }

    // ----- users -----------------------------------------------------------
    //
    // Any signed-in user can READ any profile (needed for the global
    // leaderboard, league member lookups, and the user's own profile view).
    //
    // The owner can CREATE / UPDATE their own profile, but only the
    // displayName / photoURL fields. `totals` is server-only and lives in the
    // same doc as a nested map — never let the client touch it.
    //
    // DO NOT add sensitive fields (email, phone, address, etc.) to this doc;
    // they would be world-readable.

    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isSelf(uid)
        && request.resource.data.keys().hasOnly(['displayName', 'photoURL', 'createdAt'])
        && validDisplayName(request.resource.data.displayName);

      allow update: if isSelf(uid)
        && changedKeys().hasOnly(['displayName', 'photoURL'])
        && validDisplayName(request.resource.data.displayName);

      allow delete: if false;
    }

    // ----- personality -----------------------------------------------------
    //
    // AI-generated predictor personality lives under each user's profile.
    // Read by any signed-in user (the card is shown on /users/:uid for
    // friends in your league); WRITES happen only via the
    // `generatePredictorPersonality` callable (Admin SDK, bypasses rules).
    //
    // The doc is at users/{uid}/personality/current. Listing the subcollection
    // is never needed by the client, so we keep `list` denied as a small
    // belt-and-braces measure.

    match /users/{uid}/personality/{docId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow write: if false;
    }

    // ----- users/{uid}/totals/{compId_season} ------------------------------
    //
    // Per-competition score shard. One doc per (user, comp, season), each
    // carrying that comp's running totals: total, match, podium, bracket,
    // exactScoreHits, correctOutcomeHits, updatedAt.
    //
    // Read open to any signed-in user — mirrors the policy on the parent
    // /users/{uid} doc (which has always been world-readable so leaderboards
    // can render names + totals). LIST is allowed so the lifetime-totals
    // card can sum across every shard for a user in one query; without it
    // the card would need to read each (compId, season) shard by name,
    // which it can't enumerate without listing.
    //
    // Writes are server-only — the scoreMatch trigger updates totals via
    // Admin SDK (which bypasses rules), and the migrateToMultiComp admin
    // callable does the initial backfill. Clients never write here.

    match /users/{uid}/totals/{shardId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ----- users/{uid}/devices/{deviceId} ----------------------------------
    //
    // Web-push (FCM) registration tokens, one doc per browser/device. Private
    // to the owner: the client writes its token on notification opt-in; Cloud
    // Functions read them via the Admin SDK (bypassing rules) to send pushes.

    match /users/{uid}/devices/{deviceId} {
      allow read, write: if isSelf(uid);
    }

    // ----- fixtures --------------------------------------------------------
    //
    // World-readable (for any signed-in user). All writes server-only.

    match /fixtures/{matchId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ----- fixtures/{matchId}/detail/{docId} -------------------------------
    //
    // Rich per-match detail (goals, bookings, substitutions, referees,
    // lineups) fetched from football-data's `/v4/matches/{id}` endpoint by
    // the `refreshMatchDetail` callable. Rules don't cascade into
    // subcollections, so this needs its own block — without it the read falls
    // through to the catch-all deny. World-readable for signed-in users (the
    // fixture-detail view); writes server-only via the callable (Admin SDK).

    match /fixtures/{matchId}/detail/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ----- competitions ----------------------------------------------------
    //
    // Catalogue of competitions Goalden supports. Discovered from football-data
    // by the `syncCompetitionsFromApi` admin callable; the `active` flag is
    // toggled per-comp by admins in dev-tools to gate fixture polling.
    //
    // World-readable for signed-in users so the comp picker in the create-
    // league dialog and the Predict tab's competition tabs can render. Writes
    // server-only — both discovery and the activate toggle go through admin
    // callables (which use Admin SDK and bypass these rules).

    match /competitions/{compId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ----- teams -----------------------------------------------------------
    //
    // Team info, coach, and squad. World-readable for signed-in users so we
    // can show the Teams browse view, link from fixture rows, etc. Writes
    // are server-only via the hourly pollTeams Cloud Function.

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ----- cache/* ---------------------------------------------------------
    //
    // Aggregated rollups maintained by the Cloud Function pollers, read by
    // the client to avoid expensive collection-wide reads. Single-segment
    // wildcard so every doc directly under `cache/` is covered:
    //
    //   - cache/teams           — rollup of every team doc (pollTeams)
    //   - cache/fixtures        — legacy WC-only fixtures rollup, kept
    //                             during the multi-comp cutover window
    //   - cache/fixtures-{cId}  — per-competition fixtures rollup
    //                             (pollFootballData)
    //   - cache/standings-{cId} — per-competition real standings
    //                             snapshot (added in task #66)
    //   - cache/leaderboard     — global top-100 rollup, kept current by
    //                             rebuildLeaderboard (replaces the client's
    //                             direct top-100 users listener)
    //
    // World-readable for signed-in users; all writes server-only.

    match /cache/{doc} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ----- predictions: match scores --------------------------------------
    //
    // Read: owner anytime; any signed-in user once the fixture is locked
    //   (status != 'TIMED'). The lock prevents using other users' picks to
    //   game your own. After lock, predictions are public for league
    //   comparisons + the per-user profile view.
    // Write: owner only, with strict field whitelist + lock-time check.

    match /predictions/{uid}/matches/{matchId} {
      allow read: if isSelf(uid)
        || (isSignedIn()
          && exists(/databases/$(database)/documents/fixtures/$(matchId))
          && fixture(matchId).status != 'TIMED');

      allow create, update: if isSelf(uid)
        && request.resource.data.keys().hasOnly([
          'matchId', 'homeScore', 'awayScore', 'submittedAt', 'points'
        ])
        && request.resource.data.matchId == matchId
        && request.resource.data.homeScore is int
        && request.resource.data.homeScore >= 0
        && request.resource.data.homeScore <= 99
        && request.resource.data.awayScore is int
        && request.resource.data.awayScore >= 0
        && request.resource.data.awayScore <= 99
        && isUnscoredPrediction()
        && fixture(matchId).status == 'TIMED'
        && fixture(matchId).utcKickoff > request.time;

      allow delete: if false;
    }

    // ----- predictions: podium picks ---------------------------------------
    //
    // Read: owner anytime; any other signed-in user always (pre- or
    //   post-lock). League members compare picks during the build-up
    //   to the tournament — the strategy-copying risk is minimal in
    //   practice for a friends app, and the feature value outweighs it.
    // Write: owner only, with strict field whitelist + lock-time check.

    match /predictions/{uid}/podium/picks {
      allow read: if isSelf(uid) || isSignedIn();

      allow create, update: if isSelf(uid)
        && request.resource.data.keys().hasOnly([
          'winnerTeamId', 'secondTeamId', 'thirdTeamId', 'submittedAt', 'points'
        ])
        && request.resource.data.winnerTeamId is int
        && request.resource.data.secondTeamId is int
        && request.resource.data.thirdTeamId is int
        && request.resource.data.winnerTeamId != request.resource.data.secondTeamId
        && request.resource.data.winnerTeamId != request.resource.data.thirdTeamId
        && request.resource.data.secondTeamId != request.resource.data.thirdTeamId
        && isUnscoredPrediction()
        && request.time < timestamp.date(2026, 6, 11);

      allow delete: if false;
    }

    // ----- leagues ---------------------------------------------------------
    //
    // Members of a league can read the league doc + the members subcollection.
    // All writes are server-only via Cloud Functions (createLeague, joinLeague,
    // leaveLeague, deleteLeague, regenerateInviteCode, transferOwnership,
    // kickMember).

    match /leagues/{leagueId} {
      // GET: members can always read the league doc; non-members can
      // read public/global leagues. `resource != null` guards against
      // listeners that were attached to a since-deleted doc — without
      // it, `resource.data.get(...)` throws "Null value error" and
      // Firestore surfaces a permission-denied to the client.
      allow get: if isSignedIn() && resource != null && (
        isLeagueMember(leagueId)
          || resource.data.get('type', 'private') == 'public'
          || resource.data.get('type', 'private') == 'global'
      );

      // LIST: split from GET because Firestore's static analyzer can't
      // verify a rule for a collection query when one branch is a
      // dynamic exists() (isLeagueMember). The OR causes the analyzer
      // to bail with "Type error. Received: [string] Expected: [bool]".
      //
      // Listing this collection only ever happens via
      //   query(collection('leagues'), where('type', '==', 'public'|'global'))
      // for the browse-public-leagues + global-leagues screens. The
      // analyzer can prove the rule holds when the query filters by
      // `type`, so we keep the surface narrow.
      //
      // Private-league discovery happens via the collectionGroup('members')
      // query below, NOT by listing this collection — so members never
      // need this rule to grant LIST on their private leagues.
      allow list: if isSignedIn()
        && resource.data.get('type', 'private') in ['public', 'global'];

      allow write: if false;
    }

    match /leagues/{leagueId}/members/{memberUid} {
      allow read: if isSignedIn() && isLeagueMember(leagueId);
      allow write: if false;
    }

    // Collection-group access to `members` subcollections.
    //
    // Firestore evaluates collection-group queries against rule paths that use
    // the recursive wildcard. The path-specific rule above does not match
    // `collectionGroup('members')` queries — without this block, the LeaguesService
    // "find leagues I'm in" query falls through to the catch-all deny.
    //
    // IMPORTANT: we compare against `resource.data.uid` (the doc's stored uid
    // field), NOT the `{memberUid}` path variable. Firestore can't bind path
    // variables during LIST-query static analysis, so a path-variable check
    // would fail with "Null value error" for the collection-group LIST. The
    // doc-field check works because the client's query (`where('uid', '==',
    // myUid)`) lets Firestore statically prove the rule holds for every match.
    match /{path=**}/members/{memberUid} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ----- leagues_public --------------------------------------------------
    //
    // The /j/{code} landing page reads a single doc by invite code to display
    // the league name + member count before the user has joined.
    //
    // Single-document GET is allowed for any signed-in user. LIST is denied so
    // an attacker can't iterate the collection to harvest every active invite
    // code in the system.

    match /leagues_public/{inviteCode} {
      allow get: if isSignedIn();
      allow list: if false;
      allow write: if false;
    }

    // ----- catch-all -------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

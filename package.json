{
  "name": "goalden",
  "version": "1.7.0",
  "scripts": {
    "ng": "ng",
    "start": "node tools/serve.mjs",
    "changelog:sync": "node tools/sync-changelog.mjs",
    "prebuild": "node tools/sync-changelog.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "seed:fixtures": "tsx scripts/seed-fixtures.ts",
    "icons:generate": "node tools/generate-icons.mjs",
    "emulators:kill": "kill-port 4000 4400 4500 5000 5001 8080 8085 9099 9150",
    "preemulators": "npm run emulators:kill",
    "emulators": "firebase emulators:start --import=.emulator-data --export-on-exit=.emulator-data",
    "emulators:fresh": "npm run functions:build && npm run emulators",
    "emulators:watch": "concurrently -n emu,fn -c blue,green \"npm run emulators\" \"npm run functions:watch\"",
    "functions:build": "npm --prefix functions run build",
    "functions:watch": "npm --prefix functions run build:watch",
    "snapshot": "firebase emulators:export .emulator-data --force"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/animations": "^21.2.14",
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^21.2.12",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/service-worker": "^21.1.0",
    "@material/material-color-utilities": "^0.4.0",
    "angularx-qrcode": "^21.0.5",
    "firebase": "^12.13.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "concurrently": "^10.0.0",
    "jsdom": "^27.1.0",
    "kill-port": "^2.0.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
